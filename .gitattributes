# Normalize line endings: store all text files with LF in the repo
# Working tree files keep whatever the local system uses on checkout.
* text=auto eol=lf

# Source files explicitly LF
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sh   text eol=lf
*.prisma text eol=lf

# Windows-specific scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files — git should not try to diff or convert them
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.avif binary
*.svg  text eol=lf
*.woff  binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
*.gz   binary
